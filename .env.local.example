# Configuração LOCAL com PostgreSQL via Docker
# Use este arquivo enquanto resolve o problema do Aiven

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database - PostgreSQL Local (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=sindaval_db
DB_SSL=false

# JWT
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production-min-32
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (32 caracteres)
ENCRYPTION_KEY=12345678901234567890123456789012

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Email (SMTP) - opcional para desenvolvimento
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app

# Payment Gateway - use chaves de teste
STRIPE_SECRET_KEY=sk_test_sua_chave
STRIPE_WEBHOOK_SECRET=whsec_seu_secret

# QR Code
QR_CODE_BASE_URL=http://localhost:3000/api/v1/public/validar

# WhatsApp API (opcional)
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_TOKEN=seu_token_aqui
